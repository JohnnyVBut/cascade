# ============================================================================
# Cascade — Bridge network mode template
# ============================================================================
#
# This file is a template. deploy/setup.sh generates deploy/docker-compose.bridge.yml
# from it by substituting the placeholders below:
#
#   __WG_PORT_RANGE__  — UDP port range for WireGuard, e.g. "51820-51899"
#   __CASCADE_PORT__   — Web UI management port, e.g. "8888"
#
# DO NOT use this file directly with docker compose.
# Use deploy/docker-compose.bridge.yml (generated by setup.sh).
#
# Differences from docker-compose.go.yml (host mode):
#   - No network_mode: host — container has its own network namespace
#   - ports: UDP range published to host for WireGuard traffic
#   - ports: Web UI port published to 127.0.0.1 only (Caddy proxies it)
#   - BIND_ADDR=0.0.0.0 — Cascade must bind on all interfaces inside the container
#     (port publish 127.0.0.1:PORT:PORT restricts access to localhost on the host side)
#
# ============================================================================

services:
  cascade:
    image: ghcr.io/johnnyvbut/cascade:latest
    container_name: cascade
    restart: unless-stopped

    env_file:
      - path: deploy/.env
        required: false

    environment:
      - WG_PORT=51820
      - DEBUG=false

    volumes:
      - ./data:/etc/wireguard/data
      - /etc/hostname:/host_hostname:ro

    ports:
      # Web UI: published only to localhost — Caddy (host mode) proxies it.
      # BIND_ADDR=0.0.0.0 in deploy/.env ensures Cascade listens on all interfaces
      # inside the container so Docker can forward traffic here.
      - "127.0.0.1:__CASCADE_PORT__:__CASCADE_PORT__/tcp"

      # WireGuard UDP: full range must be published at container start time.
      # Adding a new interface outside this range is not possible without restarting
      # the container with an expanded range — plan the range at deploy time.
      - "__WG_PORT_RANGE__:__WG_PORT_RANGE__/udp"

    # Enable IP forwarding inside the container's network namespace.
    # Required for WireGuard to route traffic between the veth and tunnel interfaces.
    # Docker applies this at container creation via the kernel network namespace API —
    # no CAP_SYS_ADMIN required. The host-level ip_forward set by setup.sh Step 4
    # applies to the host namespace only and does not propagate into bridge containers.
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1

    cap_add:
      - NET_ADMIN
      # SYS_MODULE is only required for kernel-module AWG mode (AWG_USERSPACE_IMPL="kernel").
      # In userspace mode (AWG_USERSPACE_IMPL=amneziawg-go, the default) it can be omitted.
      # Kept here for compatibility — harmless when the kernel module is not used.
      - SYS_MODULE

    devices:
      - /dev/net/tun:/dev/net/tun
