# Copy this file to .env and fill in the values.
# Never commit .env to git.

# Hidden path segment for the admin interface.
# Use a long random string — this is your first line of obscurity.
# Generate one: openssl rand -hex 12
ADMIN_PATH=replace-with-random-string

# Cascade Web UI port — must match PORT in docker-compose.go.yml (default 8888)
CASCADE_PORT=8888
